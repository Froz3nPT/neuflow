{
  "expo": {
    "name": "NeuFlow",
    "slug": "neuflow",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "neuflow",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neuflow.app"
    },
    "android": {
      "package": "com.neuflow.app"
    },
    "plugins": ["expo-secure-store"],
    "extra": {
      "eas": {}
    }
  }
}
