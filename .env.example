# Copy to .env (or apps/mobile/.env) and fill in.
# NEVER commit a real .env. The .gitignore already excludes it.

# Supabase — get these from https://app.supabase.com after creating a project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets go in supabase/.env.local (not here, never on the client).
# SUPABASE_SERVICE_ROLE_KEY=...
